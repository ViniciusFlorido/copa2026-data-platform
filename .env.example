# ─────────────────────────────────────────────────
# Renomeie este arquivo para .env e preencha os valores
# NUNCA suba o .env para o GitHub — ele já está no .gitignore
# ─────────────────────────────────────────────────

# Chave da API-Football (gratuita em https://www.api-football.com)
API_FOOTBALL_KEY=sua_chave_aqui

# ID da Copa do Mundo 2026 na API-Football (confirmar após cadastro)
WORLD_CUP_LEAGUE_ID=1
WORLD_CUP_SEASON=2026

# Caminhos locais (não precisa alterar)
RAW_PATH=data/raw
BRONZE_PATH=data/bronze
SILVER_PATH=data/silver
GOLD_PATH=data/gold
